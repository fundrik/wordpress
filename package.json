{
	"devDependencies": {
		"@playwright/test": "^1.52.0",
		"@wordpress/e2e-test-utils-playwright": "^1.25.0",
		"@wordpress/env": "^10.36.0",
		"@wordpress/scripts": "^31.5.0",
		"cross-env": "^10.1.0"
	},
	"scripts": {
		"build": "wp-scripts build --source-path=src/js/blocks --output-path=assets/js/blocks --blocks-manifest",
		"wp-env:start": "cross-env WP_ENV_HOME=.tmp/wp-env wp-env start",
		"wp-env:stop": "cross-env WP_ENV_HOME=.tmp/wp-env wp-env stop",
		"wp-env:destroy": "cross-env WP_ENV_HOME=.tmp/wp-env wp-env destroy",
		"test:integration": "npm run wp-env:start && cross-env WP_ENV_HOME=.tmp/wp-env wp-env run tests-cli --env-cwd=wp-content/plugins/fundrik vendor/bin/phpunit -c phpunit.integration.xml",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install-browsers": "playwright install chromium"
	}
}