<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="Fundrik Core" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/squizlabs/PHP_CodeSniffer/master/phpcs.xsd">
	<exclude-pattern>.tmp/</exclude-pattern>
	<exclude-pattern>assets/</exclude-pattern>
	<exclude-pattern>node_modules/</exclude-pattern>
	<exclude-pattern>vendor/</exclude-pattern>

	<arg value="sp"/>
	<arg name="basepath" value="."/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>
	<arg value="q"/>

	<config name="testVersion" value="8.3-"/>

	<rule ref="FundrikStandard"/>

	<rule ref="SlevomatCodingStandard.Files.TypeNameMatchesFileName">
		<properties>
			<property name="rootNamespaces" type="array">
				<element key="src/php" value="Fundrik\WordPress"/>
				<element key="tests/unit" value="Fundrik\WordPress\Tests"/>
				<element key="tests/integration" value="Fundrik\WordPress\IntegrationTests"/>
			</property>
		</properties>
	</rule>

	<rule ref="FundrikStandard.Classes.FinalClassMustBeReadonly">
		<properties>
			<property name="excludedParentClasses" type="array">
				<element value="Throwable"/>
				<element value="Fundrik\WordPress\Integration\HookDispatchers\HookDispatcherInterface"/>
			</property>
			<property name="excludedClasses" type="array">
				<element value="Fundrik\WordPress\Integration\Boot\BootUnitLogger"/>
				<element value="Fundrik\WordPress\Integration\HookDispatchers\HookDispatcherLogger"/>
				<element value="Fundrik\WordPress\Integration\WordPressContext\WordPressContext"/>
			</property>
		</properties>
	</rule>

	<rule ref="FundrikStandard.Classes.AbstractClassMustBeReadonly">
		<properties>
			<property name="excludedParentClasses" type="array">
				<element value="Throwable"/>
			</property>
		</properties>
	</rule>

	<rule ref="FundrikStandard.Classes.RequireAbstractOrFinal">
		<properties>
			<property name="excludedClasses" type="array">
				<element value="Fundrik\WordPress\Kernel\Container\ContainerBindingsRegistry" />
				<element value="Fundrik\WordPress\Infrastructure\EventDispatcher\EventListenerRegistry" />
				<element value="Fundrik\WordPress\Infrastructure\Migrations\MigrationRegistry" />
				<element value="Fundrik\WordPress\Integration\HookDispatchers\HookDispatcherRegistry"/>
				<element value="Fundrik\WordPress\Integration\PostTypes\PostTypeConfigRegistry"/>
				<element value="Fundrik\WordPress\Integration\Boot\BootUnitRegistry"/>
			</property>
			<property name="excludedParentClasses" type="array">
				<element value="Fundrik\WordPress\Integration\PostTypes\PostTypeConfigInterface"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="fundrik"/>
			</property>
		</properties>
	</rule>

	<rule ref="SlevomatCodingStandard.Classes.EmptyLinesAroundClassBraces.MultipleEmptyLinesAfterOpeningBrace">
		<exclude-pattern>*Exception.php</exclude-pattern>
		<exclude-pattern>*ExceptionInterface.php</exclude-pattern>
		<exclude-pattern>*Interface.php</exclude-pattern>
	</rule>

	<rule ref="SlevomatCodingStandard.Classes.EmptyLinesAroundClassBraces.IncorrectEmptyLinesBeforeClosingBrace">
		<exclude-pattern>*Exception.php</exclude-pattern>
		<exclude-pattern>*ExceptionInterface.php</exclude-pattern>
		<exclude-pattern>*Interface.php</exclude-pattern>
	</rule>

	<rule ref="Squiz.Commenting">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="FundrikStandard.Classes.FinalClassMustBeReadonly">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="FundrikStandard.Classes.AbstractClassMustBeReadonly">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="FundrikStandard.Commenting.SinceTagRequired">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="SlevomatCodingStandard.Complexity">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="SlevomatCodingStandard.Functions.FunctionLength">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="SlevomatCodingStandard.Files.FileLength">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="SlevomatCodingStandard.Files.LineLength">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>
	
	<rule ref="SlevomatCodingStandard.Classes.ClassLength">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="SlevomatCodingStandard.TypeHints">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="Universal.NamingConventions.NoReservedKeywordParameterNames">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>
</ruleset>